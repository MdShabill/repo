@model List<MaterialPurchaseVm>

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        padding: 30px 10px;
        margin-top: 80px;
        max-width: 100%;
    }

    .card-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .card-box {
        width: 100%;
        max-width: 1400px;
        margin: auto;
    }

    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: nowrap;
    }

    .page-title {
        text-align: center;
        font-weight: 700;
        color: #1E293B;
        margin: 0;
        flex: 1;
    }

    .left-box {
        flex-shrink: 0;
    }

    .right-box {
        flex-shrink: 0;
    }

    /* .center-box {
        justify-self: center;
    }

    .right-box {
        justify-self: end;
    } */

    .btn-orange {
        background-color: #F59E0B;
        color: white;
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 18px;
        border: none;
        text-decoration: none;
    }

        .btn-orange:hover {
            background-color: #d97706;
            color: white;
        }

    .filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }

    .filter-label {
        font-weight: 600;
        margin-right: 5px;
        position: relative;
    }

        .filter-label::after {
            content: ":";
            margin-left: 6px;
            color: #64748B;
        }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 14px;
        width: 150px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #F59E0B;
            box-shadow: 0 0 5px rgba(245,158,11,0.5);
        }

    .btn-go {
        background-color: #F59E0B;
        color: white;
        border-radius: 8px;
        padding: 6px 15px;
        border: none;
    }

        .btn-go:hover {
            background-color: #d97706;
        }

    .table {
        width: 100%;
        table-layout: auto;
    }

        .table th, .table td {
            white-space: nowrap;
            font-size: 15px;
            padding: 8px;
        }

        .table thead {
            background-color: #1E3A5F;
            color: white;
        }

        .table tbody tr:nth-child(even) {
            background-color: #f8fafc;
        }

        .table tbody tr:hover {
            background-color: #eef2f7;
        }

    .no-record {
        text-align: center;
        padding: 30px;
        font-weight: 600;
        color: #6c757d;
    }

    .title-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .purchase-badge {
        background-color: #1E3A5F;
        color: #cbd5e1;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .purchase-badge .count {
            background-color: #F59E0B;
            color: #fff;
            padding: 2px 10px;
            border-radius: 999px;
            font-weight: 700;
        }

    .cost-cell {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .cost-cell {
        background: transparent;
        padding: 0;
    }

    .cost-badge {
        display: inline-block;
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
    }

    /* Mobile Card View */
    .mobile-card {
        display: none;
    }

    @@media (max-width: 768px) {
        /* --- Top Bar Fix --- */
        .top-bar {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            flex-wrap: nowrap;
        }

        .page-title {
            font-size: 16px;
            white-space: nowrap;
            flex: 1;
            text-align: center;
        }

        .purchase-badge {
            font-size: 11px;
            padding: 5px 10px;
            white-space: nowrap;
        }

            .purchase-badge .count {
                padding: 2px 7px;
                font-size: 11px;
            }

        .btn-orange {
            font-size: 12px;
            padding: 7px 12px;
            white-space: nowrap;
        }
        /* --- Filter Fix --- */
        .filter-row {
            display: grid;
            grid-template-columns: auto 1fr;
            align-items: center;
            gap: 8px 10px;
            margin-bottom: 15px;
        }

        .filter-label {
            font-size: 13px;
            white-space: nowrap;
            margin: 0;
        }

        .form-control,
        .form-select {
            width: 100%;
            font-size: 13px;
            padding: 6px 8px;
        }

        .btn-go {
            grid-column: span 2;
            width: 100%;
            padding: 8px;
            font-size: 14px;
        }
        /* --- Table & Mobile Card --- */
        .table {
            display: none;
        }

        .mobile-card {
            display: block;
        }

        .mp-card {
            background: #fff;
            border-radius: 12px;
            border: 0.5px solid #E2E8F0;
            margin-bottom: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .mp-card-header {
            background: #1E3A5F;
            color: #fff;
            padding: 9px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .mp-card-header .supplier-name {
                font-size: 13px;
                font-weight: 600;
            }

            .mp-card-header .date {
                font-size: 11px;
                color: #94A3B8;
            }

        .mp-card-body {
            padding: 10px 14px 4px;
        }

        .mp-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 5px 0;
            border-bottom: 0.5px solid #F1F5F9;
        }

            .mp-row:last-child {
                border-bottom: none;
            }

        .mp-label {
            color: #64748B;
            font-weight: 500;
            font-size: 12px;
        }

        .mp-value {
            font-weight: 500;
            color: #1E293B;
            font-size: 13px;
            text-align: right;
        }

        .mp-card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 14px;
            border-top: 0.5px solid #F1F5F9;
            background: #FAFAFA;
        }

        .cost-badge.total {
            background: #F59E0B;
            color: #fff;
            border-color: #F59E0B;
            font-size: 14px;
            font-weight: 600;
        }
    }
</style>

<div class="container page-container">

    <div class="card-box">
        <!-- Messages -->
        <div class="text-center">
            <span class="text-success">
                <b>@TempData["SuccessMessage"] @TempData["DeleteSuccessMessage"]</b>
            </span>
        </div>

        <!-- Total -->
        <div class="top-bar">

            <!-- LEFT -->
            <div class="left-box">
                <div class="purchase-badge">
                    Total Purchase
                    <span class="count">@ViewBag.materialPurchaseCount</span>
                </div>
            </div>

            <!-- CENTER -->
            <div class="center-box">
                <h3 class="page-title mb-0">Material Purchase</h3>
            </div>

            <!-- RIGHT -->
            <div class="right-box">
                <a asp-controller="MaterialPurchase" asp-action="Add" class="btn-orange">
                    + Add New
                </a>
            </div>

        </div>

        <form method="get" asp-action="Index" onsubmit="return validateDates()" class="filter-row">

            <label class="filter-label">From</label>
            <input type="date" id="DateFrom" name="DateFrom" value="@ViewBag.DateFrom" class="form-control" />

            <label class="filter-label">To</label>
            <input type="date" id="DateTo" name="DateTo" value="@ViewBag.DateTo" class="form-control" />

            <label class="filter-label">Material</label>
            @Html.DropDownList("MaterialId", (SelectList)ViewBag.Materials, "-- Select --", new { @class = "form-select" })

            <label class="filter-label">Supplier</label>
            @Html.DropDownList("SupplierId", (SelectList)ViewBag.Supplier, "-- Select --", new { @class = "form-select" })

            <label class="filter-label">Brand</label>
            @Html.DropDownList("BrandId", (SelectList)ViewBag.Brands, "-- Select --", new { @class = "form-select" })

            <button type="submit" class="btn-go">Go</button>

        </form>

        <span id="errorMessage" class="text-danger"></span>

        <!-- Table -->
        @if (Model != null && Model.Count > 0)
        {
            <!-- DESKTOP TABLE -->
            <table class="table table-hover text-center align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Supplier Contact</th>
                        <th>Brand</th>
                        <th>Material</th>
                        <th>Unit Price</th>
                        <th>Quantity</th>
                        <th>Material Cost</th>
                        <th>Delivery Charge</th>
                        <th>Total Amount</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var totalAmount = item.MaterialCost + item.DeliveryCharge;

                        <tr>
                            <td>@item.Date.ToString("dd-MMM-yyyy")</td>
                            <td>@item.SupplierName</td>
                            <td>@item.PhoneNumber</td>
                            <td>@item.BrandName</td>
                            <td>@item.MaterialName</td>
                            <td>@item.UnitPrice.ToString("0.00") / <i>@item.UnitOfMeasure</i></td>
                            <td>@item.Quantity.ToString("0.00") / <i>@item.UnitOfMeasure</i></td>
                            <td><span class="cost-badge">@item.MaterialCost</span></td>
                            <td><span class="cost-badge">@item.DeliveryCharge</span></td>
                            <td><span class="cost-badge">₹ @totalAmount</span></td>
                            <td>
                                <form asp-action="Delete" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <button type="submit" class="btn btn-link text-danger p-0">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mobile-card">
                @foreach (var item in Model)
                {
                    var totalAmount = item.MaterialCost + item.DeliveryCharge;
                    <div class="mp-card">

                        <div class="mp-card-header">
                            <span class="supplier-name">@item.SupplierName</span>
                            <span class="date">@item.Date.ToString("dd-MMM-yyyy")</span>
                        </div>

                        <div class="mp-card-body">
                            <div class="mp-row">
                                <span class="mp-label">Contact</span>
                                <span class="mp-value">@item.PhoneNumber</span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Brand</span>
                                <span class="mp-value">@item.BrandName</span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Material</span>
                                <span class="mp-value">@item.MaterialName</span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Unit Price</span>
                                <span class="mp-value">@item.UnitPrice.ToString("0.00") / @item.UnitOfMeasure</span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Quantity</span>
                                <span class="mp-value">@item.Quantity.ToString("0.00") / @item.UnitOfMeasure</span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Material Cost</span>
                                <span class="mp-value"><span class="cost-badge">@item.MaterialCost</span></span>
                            </div>
                            <div class="mp-row">
                                <span class="mp-label">Delivery</span>
                                <span class="mp-value"><span class="cost-badge">@item.DeliveryCharge</span></span>
                            </div>
                        </div>

                        <div class="mp-card-footer">
                            <span>Total &nbsp;<span class="cost-badge total">₹ @totalAmount</span></span>
                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete this record?');">
                                <input type="hidden" name="Id" value="@item.Id" />
                                <button type="submit" class="btn btn-link text-danger p-0">Delete</button>
                            </form>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-record">
                🚫 No Record Found
            </div>
        }

    </div>
</div>

<script>
    function validateDates() {
        var dateFrom = document.getElementById("DateFrom").value;
        var dateTo = document.getElementById("DateTo").value;
        var errorMessage = document.getElementById("errorMessage");
        errorMessage.innerHTML = "";

        var currentDate = new Date().toISOString().split('T')[0];
        var fromDate = dateFrom ? new Date(dateFrom) : null;
        var toDate = dateTo ? new Date(dateTo) : null;

        if (fromDate && toDate && fromDate > toDate) {
            errorMessage.innerHTML = "FROM DATE cannot be greater than TO DATE.";
            return false;
        }

        if (dateTo && dateFrom > currentDate || dateFrom && dateTo > currentDate) {
            errorMessage.innerHTML = "FROM DATE and TO DATE cannot be in the future.";
            return false;
        }
        return true;
    }
</script>