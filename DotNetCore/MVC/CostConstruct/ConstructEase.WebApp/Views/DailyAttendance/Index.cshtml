@model List<DailyAttendanceVm>

@{
    ViewData["Title"] = "Attendance Report";
}

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        margin-top: 80px;
        padding: 30px;
    }

    /* Card */
    .card-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .page-title {
        text-align: center;
        font-weight: 700;
        color: #1E293B;
        margin-bottom: 15px;
    }

    /* Top bar */
    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    /* Filter */
    .filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: nowrap;
    }

    .date-input {
        width: 150px;
        border-radius: 8px;
    }

    .form-control {
        border-radius: 8px;
        padding: 6px 10px;
        border: 1px solid #ddd;
    }

        .form-control:focus {
            border-color: #F59E0B;
            box-shadow: 0 0 5px rgba(245,158,11,0.5);
        }

    /* Button */
    .btn-orange {
        background-color: #F59E0B;
        color: white;
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 18px;
        border: none;
        text-decoration: none;
    }

        .btn-orange:hover {
            background-color: #d97706;
            color: white;
        }

    /* Table */
    .table {
        border-radius: 12px;
        overflow: hidden;
    }

        .table thead {
            background-color: #1E3A5F;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f8fafc;
        }

    .cost-cell {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .cost-cell {
        background: transparent;
        padding: 0;
    }

    .cost-badge {
        display: inline-block;
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
    }

    .no-record {
        text-align: center;
        padding: 30px;
        font-weight: 600;
        color: #6c757d;
    }

    #errorMessage {
        color: red;
        font-weight: 500;
        margin-top: 10px;
    }
</style>

<div class="container page-container">

    <div class="card-box">

        <div class="top-bar">
            <div></div>

            <h3 class="page-title">Attendance</h3>

            <a asp-controller="DailyAttendance" asp-action="Add" class="btn btn-orange">
                + Add New
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="get" asp-action="Index" onsubmit="return validateDates()" class="filter-row mb-3">

            <label><b>From:</b></label>
            <input type="date" id="DateFrom" name="DateFrom" value="@ViewBag.DateFrom" class="form-control date-input" />

            <label><b>To:</b></label>
            <input type="date" id="DateTo" name="DateTo" value="@ViewBag.DateTo" class="form-control date-input" />

            <button type="submit" class="btn btn-orange">Go</button>

        </form>

        <span id="errorMessage"></span>

        <!-- Table -->
        @if (Model != null && Model.Count > 0)
        {
            <table class="table table-hover text-center align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Service Type</th>
                        <th>Service Providers</th>
                        <th>Total Worker</th>
                        <th>Amount Per Worker</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Date.ToString("dd MMM yyyy")</td>
                            <td>@item.Name</td>
                            <td>@item.ServiceProviderName</td>
                            <td><span class="cost-badge">@item.TotalWorker</span></td>
                            <td><span class="cost-badge">@item.AmountPerWorker</span></td>
                            <td><span class="cost-badge">₹ @item.TotalAmount</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-record">
                🚫 No Record Found
            </div>
        }

    </div>
</div>

<script>
    function validateDates() {
        var dateFrom = document.getElementById("DateFrom").value;
        var dateTo = document.getElementById("DateTo").value;
        var errorMessage = document.getElementById("errorMessage");
        errorMessage.innerHTML = "";

        var currentDate = new Date().toISOString().split('T')[0];
        var fromDate = dateFrom ? new Date(dateFrom) : null;
        var toDate = dateTo ? new Date(dateTo) : null;

        if (fromDate && toDate && fromDate > toDate) {
            errorMessage.innerHTML = "FROM DATE cannot be greater than TO DATE.";
            return false;
        }

        if (dateTo && dateFrom > currentDate || dateFrom && dateTo > currentDate) {
            errorMessage.innerHTML = "FROM DATE and TO DATE cannot be in the future.";
            return false;
        }
        return true;
    }
</script>