@model List<CostMasterVm>

@{
    ViewData["Title"] = "Cost Master";
}

<style>
    .page-container {
        margin-top: 80px;
    }

    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .page-container {
        padding: 30px;
    }

    /* Card container */
    .card-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .page-title {
        font-weight: 700;
        color: #1E293B;
        text-align: center;
        width: 100%;
    }

    /* Top section */
    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    /* Dropdown */
    .form-select {
        border-radius: 8px;
        padding: 5px 10px;
        width: 180px;
        font-size: 14px;
        background-color: #ffffff;
        color: #1E293B;
    }

        .form-select:focus {
            border-color: #F59E0B !important;
            box-shadow: 0 0 5px rgba(245, 158, 11, 0.5) !important;
        }


    .filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Orange button */
    .btn-orange {
        background-color: #F59E0B;
        color: white;
        font-weight: 600;
        border-radius: 10px;
        white-space: nowrap;
        padding: 8px 20px;
        border: none;
        text-decoration: none;
    }

    .btn-orange:hover {
        background-color: #d97706;
        color: white;
    }

    .table {
        border-radius: 12px;
        overflow: hidden;
    }

        .table thead {
            background-color: #1E3A5F;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f8fafc;
        }

    .badge-cost {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .no-record {
        text-align: center;
        padding: 30px;
        font-weight: 600;
        color: #6c757d;
    }
</style>

<div class="container page-container">

    <div class="card-box">

        <div class="top-bar">

            <div></div>

            <h3 class="page-title">Cost Master</h3>

            <a asp-controller="CostMaster" asp-action="Add" class="btn btn-orange">
                + Add New
            </a>

        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Filter -->
        <div class="mb-3">
            <form method="get" action="/CostMaster/Index" class="filter-row">

                <label><b>Service Type:</b></label>

                <select id="serviceTypeId" name="serviceTypeId" class="form-select" onchange="this.form.submit()">
                    @foreach (var item in ViewBag.ServiceType as SelectList)
                    {
                        if (item.Selected)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </form>
        </div>

        <!-- Table -->
        @if (Model != null && Model.Count > 0)
        {
            <table class="table table-hover text-center align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Service Type</th>
                        <th>Cost</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Date.ToString("dd MMM yyyy")</td>
                            <td>@item.Name</td>
                            <td>
                                <span class="badge-cost">₹ @item.Cost</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-record">
                🚫 No records found for selected service type
            </div>
        }

    </div>
</div>