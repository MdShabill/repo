@model AddNewCostMasterVm

@{
    ViewData["Title"] = "Add Cost";
}

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        margin-top: 80px;
        padding: 30px;
    }

    .card-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 500px;
        margin: auto;
    }

    .page-title {
        text-align: center;
        font-weight: 700;
        color: #1E293B;
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

    .form-control:focus {
        border-color: #F59E0B;
        box-shadow: 0 0 6px rgba(245, 158, 11, 0.5);
    }

    select.form-control {
        height: 40px;
    }

    .btn-orange {
        background-color: #F59E0B;
        color: white;
        font-weight: 600;
        border-radius: 10px;
        padding: 10px 20px;
        border: none;
    }

    .btn-orange:hover {
        background-color: #d97706;
    }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="container page-container">

    <div class="card-box">

        <h3 class="page-title">Add Cost</h3>

        <form asp-action="Add">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center"></div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger text-center">
                    <b>@ViewBag.ErrorMessage</b>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ServiceTypeId">Service Type</label>

                @Html.DropDownListFor(model => model.ServiceTypeId,
                    (SelectList)ViewBag.ServiceType,
                    "-- Select --",
                    new {
                        @class = "form-control",
                        id = "serviceTypeSelect",
                        onchange = "updateCost()"
                    })

                <span asp-validation-for="ServiceTypeId" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Cost">Cost</label>
                <input asp-for="Cost" class="form-control" id="Cost" />
                <span asp-validation-for="Cost" class="text-danger"></span>
            </div>

            <div class="text-end">
                <input type="submit" value="Add" class="btn btn-orange" />
            </div>

        </form>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function updateCost() {
        var serviceTypeId = $('#serviceTypeSelect').val();
        if (serviceTypeId) {
            $.ajax({
                url: '@Url.Action("GetCostByServiceType", "CostMaster")',
                type: 'GET',
                data: { serviceTypeId: serviceTypeId },
                success: function (result) {
                    $('#Cost').val(result.cost);
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching cost: ' + error);
                }
            });
        } else {
            $('#Cost').val('');
        }
    }
</script>