@model AddNewCostMasterVm

<h3 class="text-center mb-4">Add Cost</h3>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow p-4">

            <form asp-action="Add">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <span class="text-danger"><b>@ViewBag.ErrorMessage</b></span>

                <div class="row">

                    <div class="col-md-12 mb-3">
                        <label asp-for="Date"><b>Date</b></label>
                        <input asp-for="Date" class="form-control" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="ServiceTypeId"><b>Service Types</b></label>
                        @Html.DropDownListFor(model => model.ServiceTypeId,
                        (SelectList)ViewBag.ServiceType,
                                                "-- Select --",
                                                new { @class = "form-control", id = "serviceTypeSelect", onchange = "updateCost()" })
                        <span asp-validation-for="ServiceTypeId" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Cost"><b>Cost</b></label>
                        <input asp-for="Cost" class="form-control" id="Cost" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>

                </div>

                <div class="text-end mt-3">
                    <input type="submit" value="Add" class="btn btn-success px-4" />
                </div>

            </form>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function updateCost() {
        var serviceTypeId = $('#serviceTypeSelect').val();
        if (serviceTypeId) {
            $.ajax({
                url: '@Url.Action("GetCostByServiceType", "CostMaster")',
                type: 'GET',
                data: { serviceTypeId: serviceTypeId },
                success: function (result) {
                    $('#Cost').val(result.cost);
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching cost: ' + error);
                }
            });
        } else {
            $('#Cost').val('');
        }
    }
</script>