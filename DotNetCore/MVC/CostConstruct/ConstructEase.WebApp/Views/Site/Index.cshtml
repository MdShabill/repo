@model List<ConstructEase.WebApp.ViewModels.SiteVm>

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        padding: 30px;
        margin-top: 80px;
    }

    .card-box {
        background: #ffffff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .header-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        align-items: center;
        margin-bottom: 20px;
    }

    .title {
        text-align: center;
        font-size: 26px;
        font-weight: 600;
        color: #1E293B;
    }

    .btn-add {
        justify-self: end;
        background: #F59E0B;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-add:hover {
            background: #D97706;
        }

    .badge-box {
        display: inline-block;
        background: #1E3A5F;
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 500;
    }

        .badge-box span {
            background: #F59E0B;
            padding: 4px 10px;
            border-radius: 12px;
            margin-left: 8px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 12px;
    }

    thead {
        background: #1E3A5F;
        color: white;
    }

    th {
        padding: 14px;
        font-size: 14px;
        text-align: center;
    }

    td {
        padding: 12px;
        font-size: 16px;
        border-bottom: 1px solid #eee;
        text-align: center;
    }

    tbody tr:hover {
        background: #f9fafb;
    }

    tbody tr:nth-child(even) {
        background: #f3f4f6;
    }

    .action-links a {
        font-weight: 500;
        text-decoration: none;
        margin: 0 5px;
    }

    .edit {
        color: #16A34A;
    }

    .delete {
        color: #DC2626;
    }

    .no-record {
        text-align: center;
        padding: 20px;
        color: #888;
    }

    .mobile-cards {
        display: none;
    }

    @@media (max-width: 768px) {

        .page-container {
            padding: 14px;
            margin-top: 65px;
        }

        .card-box {
            padding: 14px;
            border-radius: 14px;
        }

        .header-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 14px;
        }

        .header-title-col {
            flex: 0 0 100%;
            text-align: center;
            order: 1;
        }

        .title {
            font-size: 19px;
            text-align: center;
        }

        .header-badge-col {
            flex: 1;
            order: 2;
            display: flex;
            align-items: center;
        }

        .header-btn-col {
            flex: 0 0 auto;
            order: 2;
            display: flex;
            align-items: center;
        }

        .badge-box {
            font-size: 12px;
            padding: 6px 10px;
            border-radius: 16px;
            white-space: nowrap;
        }

            .badge-box span {
                padding: 3px 8px;
            }

        .btn-add {
            justify-self: unset;
            padding: 8px 12px;
            font-size: 13px;
            border-radius: 8px;
            white-space: nowrap;
        }

        .desktop-table {
            display: none;
        }

        .mobile-cards {
            display: block;
        }

        .site-card {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            margin-bottom: 14px;
            overflow: hidden;
        }

        .site-card-header {
            background: #1E3A5F;
            color: #fff;
            padding: 10px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .site-card-header .site-name {
                font-size: 14px;
                font-weight: 600;
            }

            .site-card-header .site-status {
                font-size: 12px;
                color: #F59E0B;
                font-weight: 500;
            }

        .site-card-body {
            padding: 4px 14px;
        }

        .site-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 7px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 13px;
        }

            .site-row:last-child {
                border-bottom: none;
            }

        .site-label {
            color: #64748B;
            flex: 0 0 100px;
        }

        .site-value {
            color: #1E293B;
            font-weight: 500;
            text-align: right;
            flex: 1;
        }

        .site-card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 14px;
            border-top: 1px solid #f1f5f9;
            background: #fafafa;
        }

            .site-card-footer .edit {
                font-size: 14px;
                font-weight: 500;
                text-decoration: none;
            }

            .site-card-footer .delete {
                font-size: 14px;
                font-weight: 500;
                border: none;
                background: none;
                cursor: pointer;
                padding: 0;
            }
    }
</style>

<div class="page-container">
    <div class="card-box">

        <div class="header-row">
            <div class="header-badge-col">
                <div class="badge-box">
                    Total Sites <span>@ViewBag.SiteCount</span>
                </div>
            </div>
            <div class="header-title-col">
                <div class="title">Site List</div>
            </div>
            <div class="header-btn-col">
                <a asp-controller="Site" asp-action="Add" class="btn-add">+ Add New</a>
            </div>
        </div>

        <span class="text-success">
            @TempData["AddSuccessMessage"]
            @TempData["UpdateSuccessMessage"]
            @TempData["DeleteSuccessMessage"]
        </span>
        @if (ViewBag.ErrorMessage != null)
        {
            <span class="text-danger">@ViewBag.ErrorMessage</span>
        }

        <div class="desktop-table">
            <table>
                <thead>
                    <tr>
                        <th>Site Name</th>
                        <th>Started Date</th>
                        <th>Status</th>
                        <th>Address</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var site in Model)
                        {
                            <tr>
                                <td><b>@site.Name</b></td>
                                <td>@site.StartedDate.ToString("dd-MMM-yyyy")</td>
                                <td>@site.Status</td>
                                <td>
                                    @($"{site.AddressTypes} - {site.AddressLine1} - {site.CountryName} - {site.PinCode}")
                                </td>
                                <td>
                                    <a asp-controller="Site" asp-action="Edit"
                                       asp-route-id="@site.Id"
                                       class="edit">Edit</a> |
                                    <form asp-action="Delete" asp-controller="Site"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this site?');">
                                        <input type="hidden" name="siteId" value="@site.Id" />
                                        <button type="submit" class="delete" style="border:none;background:none;">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="no-record">No site records found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mobile-cards">
            @if (Model != null && Model.Any())
            {
                foreach (var site in Model)
                {
                    <div class="site-card">
                        <div class="site-card-header">
                            <span class="site-name">@site.Name</span>
                            <span class="site-status">@site.Status</span>
                        </div>
                        <div class="site-card-body">
                            <div class="site-row">
                                <span class="site-label">Started</span>
                                <span class="site-value">@site.StartedDate.ToString("dd-MMM-yyyy")</span>
                            </div>
                            <div class="site-row">
                                <span class="site-label">Address</span>
                                <span class="site-value" style="color:#64748B; font-weight:400;">
                                    @($"{site.AddressTypes} - {site.AddressLine1} - {site.CountryName} - {site.PinCode}")
                                </span>
                            </div>
                        </div>
                        <div class="site-card-footer">
                            <a asp-controller="Site" asp-action="Edit"
                               asp-route-id="@site.Id"
                               class="edit">Edit</a>
                            <form asp-action="Delete" asp-controller="Site"
                                  method="post" style="display:inline;"
                                  onsubmit="return confirm('Are you sure you want to delete this site?');">
                                <input type="hidden" name="siteId" value="@site.Id" />
                                <button type="submit" class="delete">Delete</button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="no-record">No site records found.</p>
            }
        </div>

    </div>
</div>
