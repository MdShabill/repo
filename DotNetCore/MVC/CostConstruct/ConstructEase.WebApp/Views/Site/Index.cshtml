@model List<ConstructEase.WebApp.ViewModels.SiteVm>

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        padding: 30px;
        margin-top: 80px;
    }

    .card-box {
        background: #ffffff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    /* Header */
    .header-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        align-items: center;
        margin-bottom: 20px;
    }

    .title {
        text-align: center;
        font-size: 26px;
        font-weight: 600;
        color: #1E293B;
    }

    .btn-add {
        justify-self: end;
        background: #F59E0B;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-add:hover {
            background: #D97706;
        }

    /* Table */
    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 12px;
    }

    thead {
        background: #1E3A5F;
        color: white;
    }

    th {
        padding: 14px;
        font-size: 14px;
        text-align: center;
    }

    td {
        padding: 12px;
        font-size: 16px;
        border-bottom: 1px solid #eee;
        text-align: center;
    }

    tbody tr:hover {
        background: #f9fafb;
    }

    tbody tr:nth-child(even) {
        background: #f3f4f6;
    }

    .action-links a {
        font-weight: 500;
        text-decoration: none;
        margin: 0 5px;
    }

    .edit {
        color: #16A34A;
    }

    .delete {
        color: #DC2626;
    }

    .no-record {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">
    <div class="card-box">

        <!-- Header -->
        <div class="header-row">
            <div></div>

            <div class="title">Site List</div>

            <a asp-controller="Site" asp-action="Add" class="btn-add">+ Add New</a>
        </div>

        <!-- Messages -->
        <span class="text-success">
            @TempData["AddSuccessMessage"]
            @TempData["UpdateSuccessMessage"]
            @TempData["DeleteSuccessMessage"]
        </span>

        <!-- Table -->
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>SL</th>
                        <th>Site Name</th>
                        <th>Started Date</th>
                        <th>Status</th>
                        <th>Address</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int count = 1;
                        foreach (var site in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td><b>@site.Name</b></td>
                                <td>@site.StartedDate.ToString("dd-MMM-yyyy")</td>
                                <td>@site.Status</td>
                                <td>
                                    @($"{site.AddressTypes} - {site.AddressLine1} - {site.CountryName} - {site.PinCode}")
                                </td>
                                <td>
                                    <a asp-controller="Site" asp-action="Edit"
                                       asp-route-id="@site.Id"
                                       class="edit">Edit</a> |

                                    <form asp-action="Delete"
                                          asp-controller="Site"
                                          method="post"
                                          style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this site?');">

                                        <input type="hidden" name="siteId" value="@site.Id" />
                                        <button type="submit"
                                                class="delete"
                                                style="border:none;background:none;">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            count++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-record">
                                No site records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>