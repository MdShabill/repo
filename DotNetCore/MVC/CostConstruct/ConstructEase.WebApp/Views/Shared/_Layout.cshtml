@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    var email = Context.Session.GetString("Email");
    var selectedSiteName = Context.Session.GetString("SelectedSiteName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Builder Ledger - Construction & Financial Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConstructEase.WebApp.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        :root {
            --ce-navy: #1a2e44;
            --ce-amber: #f0a500;
            --ce-amber-hover: #d4920a;
            --ce-text: #374151;
            --ce-muted: #6b7280;
            --ce-border: #e8e6e0;
            --ce-surface: #f5f3ee;
        }

        body {
            font-family: 'Outfit', sans-serif;
        }

        /* ── Navbar ── */
        .ce-navbar {
            background: #fff;
            border-bottom: 1px solid var(--ce-border);
            padding: 0 1.5rem;
            height: 68px;
            display: flex;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

            .ce-navbar .container-fluid {
                display: grid;
                grid-template-columns: auto 1fr auto;
                align-items: center;
            }

        .ce-nav-links {
            gap: 20px;
        }

        .ce-nav-links {
            justify-content: center;
        }

        .ce-nav-collapse {
            display: flex;
            align-items: center;
            justify-content: center;
            grid-column: 2;
        }

        /* Logo */
        .ce-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
        }

            .ce-brand img {
                width: 80px;
                height: 60px;
                object-fit: contain;
            }

        /* Nav links */
        .ce-nav-links {
            display: flex;
            align-items: center;
            gap: 18px;
            list-style: none;
            margin: 0;
            padding: 0;
            justify-content: center;
            transform: translateX(40px);
        }

            .ce-nav-links .nav-item .nav-link {
                color: #000 !important;
                font-size: 15px;
                font-weight: 600;
            }

                .ce-nav-links .nav-item .nav-link:hover,
                .ce-nav-links .nav-item .nav-link.active {
                    color: #000 !important;
                    background: var(--ce-surface);
                }

        /* Right section */
        .ce-nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .ce-site-label {
            font-size: 11px;
            font-weight: 700;
            color: #9ca3af;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .ce-select {
            border: 1.5px solid #d1ccbb;
            border-radius: 7px;
            padding: 7px 10px;
            font-size: 13px;
            font-family: 'Outfit', sans-serif;
            font-weight: 500;
            color: var(--ce-text);
            background: #fff;
            outline: none;
            width: 170px;
            cursor: pointer;
            transition: border-color 0.15s;
            appearance: auto;
        }

            .ce-select:focus {
                border-color: var(--ce-amber);
            }

        .ce-btn-go {
            background: var(--ce-amber);
            color: #fff;
            border: none;
            border-radius: 7px;
            padding: 7px 20px;
            font-size: 13px;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            letter-spacing: 0.3px;
            transition: background 0.15s;
            white-space: nowrap;
        }

            .ce-btn-go:hover {
                background: var(--ce-amber-hover);
            }

        .ce-divider {
            width: 1px;
            height: 26px;
            background: var(--ce-border);
        }

        .ce-welcome {
            font-size: 13px;
            font-weight: 500;
            color: var(--ce-muted);
            white-space: nowrap;
        }

        .ce-btn-logout {
            padding: 7px 16px;
            font-size: 13px;
            font-weight: 600;
            color: var(--ce-navy);
            border: 1.5px solid var(--ce-navy);
            border-radius: 7px;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
            white-space: nowrap;
        }

            .ce-btn-logout:hover {
                background: var(--ce-navy);
                color: #fff;
            }

        /* Mobile toggler */
        .ce-toggler {
            display: none;
            background: none;
            border: 1.5px solid var(--ce-border);
            border-radius: 7px;
            padding: 6px 10px;
            cursor: pointer;
        }

        /* ── Footer ── */
        .ce-footer {
            background: #fff;
            border-top: 1px solid var(--ce-border);
            padding: 1.25rem 0;
            font-size: 13px;
            color: var(--ce-muted);
        }

            .ce-footer a {
                color: var(--ce-amber);
                text-decoration: none;
            }

                .ce-footer a:hover {
                    text-decoration: underline;
                }

        /* ── Responsive ── */
        @@media (max-width: 991px) {

            .ce-navbar .container-fluid {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .ce-toggler {
                display: block;
                margin-left: auto;
            }

            .ce-nav-collapse {
                position: fixed;
                top: 0;
                right: -100%;
                width: 50%;
                height: 100vh;
                background: #fff;
                padding: 20px;
                flex-direction: column;
                transition: right 0.3s ease;
                z-index: 1050;
                position: fixed;
                overflow-y: auto;
                box-shadow: -2px 0 10px rgba(0,0,0,0.1);
            }

                .ce-nav-collapse.open {
                    right: 0;
                }

            .ce-nav-links {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
                margin-top: 20px;
            }

            .ce-nav-right {
                flex-direction: column;
                align-items: flex-start;
                margin-top: 20px;
                width: 100%;
            }
        }
    </style>
</head>
<body>

    <header>
        <nav class="ce-navbar">
            <div class="container-fluid">
                <!-- Logo -->
                <a class="ce-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/UploadedImage/WebSiteLogo.jpg" alt="ConstructEase Logo" />
                </a>

                <!-- Mobile toggler -->
                <button class="ce-toggler" id="ceNavToggler" aria-label="Toggle navigation">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect y="2" width="18" height="2" rx="1" fill="#374151" />
                        <rect y="8" width="18" height="2" rx="1" fill="#374151" />
                        <rect y="14" width="18" height="2" rx="1" fill="#374151" />
                    </svg>
                </button>

                <!-- Collapsible content -->
                <div class="ce-nav-collapse" id="ceNavCollapse">

                    @if (userId != null)
                    {
                        <!-- CENTER: Nav links -->
                        <ul class="ce-nav-links mx-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="CostMaster" asp-action="Index">Cost Master</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="DailyAttendance" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="MaterialPurchase" asp-action="Index">Material</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ServiceProvider" asp-action="Index">Service Provider</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Site" asp-action="Index">Site</a>
                            </li>
                        </ul>

                        <!-- RIGHT -->
                        <div class="ce-nav-right">
                            <form asp-controller="Site" asp-action="Index" method="post" style="display:flex; align-items:center; gap:8px;">
                                <span class="ce-site-label">Site</span>
                                <select name="Id" class="ce-select" asp-items="ViewBag.Site" required>
                                    <option value="">-- Select Site --</option>
                                </select>
                                <button type="submit" class="ce-btn-go">Go</button>
                            </form>

                            <div class="ce-divider"></div>

                            <span class="ce-welcome">Welcome, @userName</span>

                            <a class="ce-btn-logout" asp-controller="Account" asp-action="LogOut">Log Out</a>
                        </div>
                    }

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const toggler = document.getElementById('ceNavToggler');
        const collapse = document.getElementById('ceNavCollapse');

        toggler?.addEventListener('click', (e) => {
            e.stopPropagation();
            collapse.classList.toggle('open');
        });

        collapse.addEventListener('click', (e) => {
            e.stopPropagation();
        });

        document.addEventListener('click', (e) => {
            const isClickInsideMenu = collapse.contains(e.target);
            const isClickOnToggler = toggler.contains(e.target);

            if (!isClickInsideMenu && !isClickOnToggler) {
                collapse.classList.remove('open');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</body>
</html>