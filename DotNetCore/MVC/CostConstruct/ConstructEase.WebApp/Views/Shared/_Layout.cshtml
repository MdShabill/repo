@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    var email = Context.Session.GetString("Email");
    var selectedSiteName = Context.Session.GetString("SelectedSiteName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Builder Ledger - Construction & Financial Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConstructEase.WebApp.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        :root {
            --ce-navy: #1a2e44;
            --ce-amber: #f0a500;
            --ce-amber-hover: #d4920a;
            --ce-text: #374151;
            --ce-muted: #6b7280;
            --ce-border: #e8e6e0;
            --ce-surface: #f5f3ee;
        }

        body {
            font-family: 'Outfit', sans-serif;
        }

        /* ── Navbar ── */
        .ce-navbar {
            background: #fff;
            border-bottom: 1px solid var(--ce-border);
            padding: 0 1.5rem;
            height: 68px;
            display: flex;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

            /* Desktop: single flex row, space-between */
            .ce-navbar .container-fluid {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
                width: 100%;
            }

        /* Logo */
        .ce-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
        }

            .ce-brand img {
                width: 80px;
                height: 60px;
                object-fit: contain;
            }

        /* Desktop collapsible area — flex row */
        .ce-nav-collapse {
            display: flex;
            align-items: center;
            flex: 1;
            gap: 0;
        }

        /* Nav links */
        .ce-nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0;
            flex-shrink: 0;
        }

            .ce-nav-links .nav-item .nav-link {
                color: #000 !important;
                font-size: 15px;
                font-weight: 600;
                padding: 6px 10px;
                border-radius: 6px;
                white-space: nowrap;
            }

                .ce-nav-links .nav-item .nav-link:hover,
                .ce-nav-links .nav-item .nav-link.active {
                    color: #000 !important;
                    background: var(--ce-surface);
                }

        /* Right section — site selector + welcome + logout */
        .ce-nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
            margin-left: auto;
        }

        .ce-site-label {
            font-size: 11px;
            font-weight: 700;
            color: #9ca3af;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .ce-select {
            border: 1.5px solid #d1ccbb;
            border-radius: 7px;
            padding: 7px 10px;
            font-size: 13px;
            font-family: 'Outfit', sans-serif;
            font-weight: 500;
            color: var(--ce-text);
            background: #fff;
            outline: none;
            width: 170px;
            cursor: pointer;
            transition: border-color 0.15s;
            appearance: auto;
        }

            .ce-select:focus {
                border-color: var(--ce-amber);
            }

        .ce-btn-go {
            background: var(--ce-amber);
            color: #fff;
            border: none;
            border-radius: 7px;
            padding: 7px 20px;
            font-size: 13px;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            letter-spacing: 0.3px;
            transition: background 0.15s;
            white-space: nowrap;
        }

            .ce-btn-go:hover {
                background: var(--ce-amber-hover);
            }

        .ce-divider {
            width: 1px;
            height: 26px;
            background: var(--ce-border);
        }

        .ce-welcome {
            font-size: 13px;
            font-weight: 500;
            color: var(--ce-muted);
            white-space: nowrap;
        }

        .ce-btn-logout {
            padding: 7px 16px;
            font-size: 13px;
            font-weight: 600;
            color: var(--ce-navy);
            border: 1.5px solid var(--ce-navy);
            border-radius: 7px;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
            white-space: nowrap;
        }

            .ce-btn-logout:hover {
                background: var(--ce-navy);
                color: #fff;
            }

        /* Hide mobile-only elements on desktop */
        .ce-user-strip,
        .ce-avatar,
        .ce-logged-in,
        .ce-nav-bottom,
        .ce-site-card {
            display: none;
        }

        /* Desktop site form inline */
        .ce-site-form-desktop {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Mobile toggler — hidden on desktop */
        .ce-toggler {
            display: none;
            background: none;
            border: 1.5px solid var(--ce-border);
            border-radius: 7px;
            padding: 6px 10px;
            cursor: pointer;
        }

        /* ── Footer ── */
        .ce-footer {
            background: #fff;
            border-top: 1px solid var(--ce-border);
            padding: 1.25rem 0;
            font-size: 13px;
            color: var(--ce-muted);
        }

            .ce-footer a {
                color: var(--ce-amber);
                text-decoration: none;
            }

                .ce-footer a:hover {
                    text-decoration: underline;
                }

        /* ── Responsive ── */
        @@media (max-width: 991px) {

            .ce-navbar .container-fluid {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .ce-toggler {
                display: block;
                margin-left: auto;
            }
            /* Hide desktop-only elements on mobile */
            .ce-site-form-desktop,
            .ce-welcome-desktop,
            .ce-divider {
                display: none !important;
            }
            /* Slide-in drawer */
            .ce-nav-collapse {
                position: fixed;
                top: 0;
                right: -100%;
                width: 75%;
                max-width: 300px;
                height: 100vh;
                background: #fff;
                display: flex;
                flex-direction: column;
                align-items: stretch;
                transition: right 0.3s ease;
                z-index: 1050;
                overflow-y: auto;
                box-shadow: -4px 0 20px rgba(0,0,0,0.15);
                padding: 0;
            }

                .ce-nav-collapse.open {
                    right: 0;
                }
            /* ── Top: navy welcome strip ── */
            .ce-nav-right {
                background: #1a2e44;
                padding: 20px 18px 18px;
                flex-shrink: 0;
                margin-left: 0;
            }

            .ce-user-strip {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .ce-avatar {
                display: flex;
                width: 42px;
                height: 42px;
                min-width: 42px;
                background: #f0a500;
                border-radius: 50%;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                font-weight: 700;
                color: #fff;
            }

            .ce-welcome {
                display: block;
                font-size: 15px;
                font-weight: 600;
                color: #ffffff;
                white-space: normal;
            }

            .ce-logged-in {
                display: block;
                font-size: 12px;
                color: #94a3b8;
                margin-top: 2px;
            }
            /* ── Middle: nav links ── */
            .ce-nav-links {
                flex-direction: column;
                align-items: stretch;
                gap: 0;
                margin: 0;
                padding: 8px 0;
                flex: 1;
            }

                .ce-nav-links .nav-item {
                    border-left: 3px solid transparent;
                    transition: border-color 0.15s, background 0.15s;
                }

                    .ce-nav-links .nav-item:hover {
                        background: #f8fafc;
                        border-left-color: #f0a500;
                    }

                    .ce-nav-links .nav-item .nav-link {
                        padding: 13px 18px !important;
                        font-size: 14px !important;
                        font-weight: 600 !important;
                        color: #1a2e44 !important;
                        display: block;
                        border-radius: 0;
                    }

                        .ce-nav-links .nav-item .nav-link:hover {
                            background: transparent !important;
                            color: #1a2e44 !important;
                        }
            /* ── Bottom: site selector + logout ── */
            .ce-nav-bottom {
                display: block;
                padding: 12px;
                border-top: 1px solid #f1f5f9;
                flex-shrink: 0;
            }

            .ce-site-card {
                display: block;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 10px;
                padding: 12px 14px;
                margin-bottom: 10px;
            }

            .ce-site-label {
                display: block;
                font-size: 11px;
                font-weight: 700;
                color: #94a3b8;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                margin-bottom: 10px;
            }

            .ce-site-form {
                display: flex;
                gap: 8px;
                align-items: center;
            }

            .ce-select {
                flex: 0 0 auto;
                width: auto;
                font-size: 14px;
                padding: 9px 10px;
            }

            .ce-btn-go {
                padding: 9px 18px;
                font-size: 14px;
                border-radius: 8px;
                white-space: nowrap;
            }

            .ce-btn-logout {
                display: block;
                width: 100%;
                text-align: center;
                padding: 11px;
                border-radius: 8px;
                font-size: 14px;
                box-sizing: border-box;
            }

            .ce-divider {
                display: none;
            }
        }
    </style>
</head>
<body>

    <header>
        <nav class="ce-navbar">
            <div class="container-fluid">
                <!-- Logo -->
                <a class="ce-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/UploadedImage/WebSiteLogo.jpg" alt="ConstructEase Logo" />
                </a>

                <!-- Mobile toggler -->
                <button class="ce-toggler" id="ceNavToggler" aria-label="Toggle navigation">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect y="2" width="18" height="2" rx="1" fill="#374151" />
                        <rect y="8" width="18" height="2" rx="1" fill="#374151" />
                        <rect y="14" width="18" height="2" rx="1" fill="#374151" />
                    </svg>
                </button>

                <!-- Collapsible content -->
                <div class="ce-nav-collapse" id="ceNavCollapse">

                    @if (userId != null)
                    {
                        <!-- TOP (mobile only): navy welcome strip -->
                        <div class="ce-nav-right">
                            <div class="ce-user-strip">
                                <div class="ce-avatar">@(userName?.Substring(0, 1).ToUpper() ?? "U")</div>
                                <div>
                                    <span class="ce-welcome">Welcome, @userName</span>
                                    <span class="ce-logged-in">Logged in</span>
                                </div>
                            </div>
                        </div>

                        <!-- CENTER: Nav links (desktop: horizontal row | mobile: vertical list) -->
                        <ul class="ce-nav-links">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="CostMaster" asp-action="Index">Cost Master</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="DailyAttendance" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="MaterialPurchase" asp-action="Index">Material</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ServiceProvider" asp-action="Index">Service Provider</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Site" asp-action="Index">Site</a>
                            </li>
                        </ul>

                        <!-- RIGHT (desktop only): site selector + welcome + logout -->
                        <div class="ce-site-form-desktop" style="margin-left:auto; display:flex; align-items:center; gap:8px;">
                            <span class="ce-site-label" style="display:block;">SITE</span>
                            <form asp-controller="Site" asp-action="Index" method="post" style="display:flex;align-items:center;gap:6px;">
                                <select name="Id" class="ce-select" asp-items="ViewBag.Site" required>
                                    <option value="">-- Select Site --</option>
                                </select>
                                <button type="submit" class="ce-btn-go">Go</button>
                            </form>
                            <div class="ce-divider"></div>
                            <span class="ce-welcome ce-welcome-desktop">Welcome, @userName</span>
                            <a class="ce-btn-logout" asp-controller="Account" asp-action="LogOut">Log Out</a>
                        </div>

                        <!-- BOTTOM (mobile only): site selector + logout -->
                        <div class="ce-nav-bottom">
                            <div class="ce-site-card">
                                <span class="ce-site-label">Select Site</span>
                                <form asp-controller="Site" asp-action="Index" method="post" class="ce-site-form">
                                    <select name="Id" class="ce-select" asp-items="ViewBag.Site" required>
                                        <option value="">-- Select Site --</option>
                                    </select>
                                    <button type="submit" class="ce-btn-go">Go</button>
                                </form>
                            </div>
                            <a class="ce-btn-logout" asp-controller="Account" asp-action="LogOut">Log Out</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const toggler = document.getElementById('ceNavToggler');
        const collapse = document.getElementById('ceNavCollapse');

        toggler?.addEventListener('click', (e) => {
            e.stopPropagation();
            collapse.classList.toggle('open');
        });

        collapse.addEventListener('click', (e) => {
            e.stopPropagation();
        });

        document.addEventListener('click', (e) => {
            const isClickInsideMenu = collapse.contains(e.target);
            const isClickOnToggler = toggler.contains(e.target);

            if (!isClickInsideMenu && !isClickOnToggler) {
                collapse.classList.remove('open');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
