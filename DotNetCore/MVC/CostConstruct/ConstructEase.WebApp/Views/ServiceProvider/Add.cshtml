@model ConstructEase.WebApp.ViewModels.ServiceProviderVm

<h3 class="text-center my-4 fw-bold">Add Service Provider</h3>

<div class="row justify-content-center">
    <div class="col-md-6">
        <form asp-action="Add" method="post" enctype="multipart/form-data" class="border p-4 rounded shadow bg-light">

            <span class="text-danger"><b>@ViewBag.errorMessage</b></span>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ServiceProviderName" class="fw-bold">Service Provider Name</label>
                <input asp-for="ServiceProviderName" class="form-control" maxlength="15" required />
            </div>

            <div class="form-group mb-3">
                <label class="fw-bold">Gender</label><br />
                @Html.RadioButton("Gender", "Male", true) Male
                @Html.RadioButton("Gender", "Female") Female
                @Html.RadioButton("Gender", "Transgender") Transgender
                @Html.RadioButton("Gender", "Others") Others
            </div>

            <div class="form-group mb-3">
                <label asp-for="DOB" class="fw-bold">Date Of Birth</label>
                <input asp-for="DOB" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="fw-bold">Profile Image</label>
                <input type="file" class="form-control" id="ImageFile" name="ImageFile" />
            </div>
      
            <div class="form-group mb-3">
                <label asp-for="MobileNumber" class="fw-bold">Mobile Number</label>
                <input asp-for="MobileNumber" class="form-control" maxlength="10" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReferredBy" class="fw-bold">Referred By</label>
                <input asp-for="ReferredBy" class="form-control" maxlength="15" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="ServiceTypeId" class="fw-bold">Service Type</label>
                @Html.DropDownListFor(model => model.ServiceTypeId,
                (SelectList)ViewBag.ServiceType,
                                "-- SELECT SERVICE TYPE --",
                                new { @class = "form-control" })
            </div>

            <!-- Toggle Address -->
            <button type="button" id="btnToggleAddressButton" class="btn btn-secondary mb-3" onclick="toggleAddressFields()">
                Tap for Address
            </button>

            <div id="dvAddressFields" style="display: none;">

                <div class="form-group mb-3">
                    <label asp-for="AddressLine1" class="fw-bold">Address</label>
                    <input asp-for="AddressLine1" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="AddressTypeId" class="fw-bold">Address Type</label>
                    @Html.DropDownListFor(model => model.AddressTypeId,
                                        (SelectList)ViewBag.AddressTypes,
                                        "-- Select --",
                                        new { @class = "form-control" })
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CountryId" class="fw-bold">Country Name</label>
                    @Html.DropDownListFor(model => model.CountryId,
                                        ViewBag.Countries as SelectList,
                                        "-- Select --",
                                        new { @class = "form-control" })
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PinCode" class="fw-bold">Pin Code</label>
                    <input asp-for="PinCode" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                &nbsp;&nbsp;&nbsp;
                <a asp-controller="ServiceProvider" asp-action="Index" class="btn btn-secondary">Back</a>
            </div>

        </form>
    </div>
</div>

<script>
    function toggleAddressFields() {
        const addressFields = document.getElementById("dvAddressFields");
        const button = document.getElementById("btnToggleAddressButton");

        if (addressFields.style.display === "none") {
            addressFields.style.display = "block";
            button.textContent = "Tap to Hide Address";
        } else {
            addressFields.style.display = "none";
            button.textContent = "Tap for Address";
        }
    }
</script>