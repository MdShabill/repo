@model List<ConstructEase.WebApp.ViewModels.ServiceProviderVm>

@{
    ViewData["Title"] = "Service Providers";
}

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        padding: 30px;
        margin-top: 80px;
    }

    .card-box {
        background: #ffffff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .header-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        margin-bottom: 20px;
    }

    .header-left {
        justify-self: start;
    }

    .header-center {
        justify-self: center;
    }

    .header-right {
        justify-self: end;
    }

    .title {
        font-size: 28px;
        font-weight: 600;
        color: #1E293B;
    }

    .btn-add {
        background: #F59E0B;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-add:hover {
            background: #D97706;
        }

    .badge-box {
        display: inline-block;
        background: #1E3A5F;
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 500;
        margin-bottom: 15px;
    }

        .badge-box span {
            background: #F59E0B;
            padding: 4px 10px;
            border-radius: 12px;
            margin-left: 8px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 12px;
    }

    thead {
        background: #1E3A5F;
        color: white;
    }

    th {
        padding: 14px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 12px;
        font-size: 16px;
        border-bottom: 1px solid #eee;
    }

    tbody tr:hover {
        background: #f9fafb;
    }

    .action-link {
        color: #16A34A;
        font-weight: 500;
        text-decoration: none;
        margin-right: 8px;
    }

        .action-link:hover {
            text-decoration: underline;
        }

    .delete-link {
        color: #DC2626;
        font-weight: 500;
        border: none;
        background: none;
        cursor: pointer;
        padding: 0;
    }

        .delete-link:hover {
            text-decoration: underline;
        }

    .address-text {
        color: #64748B;
        font-size: 16px;
    }

    .no-data {
        text-align: center;
        padding: 20px;
        color: #888;
    }

    .mobile-cards {
        display: none;
    }

    @@media (max-width: 768px) {

        .page-container {
            padding: 14px;
            margin-top: 65px;
        }

        .card-box {
            padding: 14px;
            border-radius: 14px;
        }

        .header-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 14px;
        }

        .header-center {
            flex: 0 0 100%;
            text-align: center;
            order: 1;
        }

        .title {
            font-size: 19px;
        }

        .header-left {
            flex: 1;
            order: 2;
            display: flex;
            align-items: center;
        }

        .header-right {
            flex: 0 0 auto;
            order: 2;
            display: flex;
            align-items: center;
        }

        .badge-box {
            font-size: 12px;
            padding: 6px 10px;
            border-radius: 16px;
            margin-bottom: 0;
            white-space: nowrap;
        }

            .badge-box span {
                padding: 3px 8px;
            }

        .btn-add {
            padding: 8px 12px;
            font-size: 13px;
            border-radius: 8px;
            white-space: nowrap;
        }

        .desktop-table {
            display: none;
        }

        .mobile-cards {
            display: block;
        }

        .sp-card {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            margin-bottom: 14px;
            overflow: hidden;
        }

        .sp-card-header {
            background: #1E3A5F;
            color: #fff;
            padding: 10px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .sp-card-header .sp-name {
                font-size: 14px;
                font-weight: 600;
            }

            .sp-card-header .sp-type {
                font-size: 12px;
                color: #F59E0B;
                font-weight: 500;
            }
 
        .sp-card-body {
            padding: 4px 14px;
        }

        .sp-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 7px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 13px;
        }

            .sp-row:last-child {
                border-bottom: none;
            }

        .sp-label {
            color: #64748B;
            flex: 0 0 90px;
        }

        .sp-value {
            color: #1E293B;
            font-weight: 500;
            text-align: right;
            flex: 1;
        }

        .sp-card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 14px;
            border-top: 1px solid #f1f5f9;
            background: #fafafa;
        }

            .sp-card-footer .action-link {
                font-size: 14px;
            }

            .sp-card-footer .delete-link {
                font-size: 14px;
            }
    }
</style>

<div class="page-container">
    <div class="card-box">

        <div class="header-row">
            <div class="header-left">
                <div class="badge-box">
                    Total Service Providers <span>@ViewBag.ServiceProviderCount</span>
                </div>
            </div>

            <div class="header-center">
                <div class="title">Service Providers / Vendor</div>
            </div>

            <div class="header-right">
                <a asp-controller="ServiceProvider" asp-action="Add" class="btn-add">+ Add New</a>
            </div>
        </div>

        <span class="text-success">
            @TempData["AddSuccessMessage"]
            @TempData["UpdateSuccessMessage"]
            @TempData["DeleteSuccessMessage"]
        </span>

        <div class="desktop-table">
            <table>
                <thead>
                    <tr>
                        <th>Service Type</th>
                        <th>Name</th>
                        <th>Gender</th>
                        <th>Mobile</th>
                        <th>Referred By</th>
                        <th>Address</th>
                        <th style="width:140px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ServiceTypes</td>
                                <td>@item.ServiceProviderName</td>
                                <td>@item.Gender</td>
                                <td>@item.MobileNumber</td>
                                <td>@item.ReferredBy</td>
                                <td class="address-text">
                                    @($"{item.AddressTypes} - {item.AddressLine1} - {item.CountryName} - {item.PinCode}")
                                </td>
                                <td>
                                    <a href="@Url.Action("Edit", "ServiceProvider", new { id = item.ServiceProviderId })"
                                       class="action-link">Edit</a>
                                    <form asp-action="Delete" asp-controller="ServiceProvider"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this service Provider?');">
                                        <input type="hidden" name="ServiceProviderId" value="@item.ServiceProviderId" />
                                        <button type="submit" class="delete-link">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="no-data">No Service Providers found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mobile-cards">
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <div class="sp-card">
                        <div class="sp-card-header">
                            <span class="sp-name">@item.ServiceProviderName</span>
                            <span class="sp-type">@item.ServiceTypes</span>
                        </div>
                        <div class="sp-card-body">
                            <div class="sp-row">
                                <span class="sp-label">Gender</span>
                                <span class="sp-value">@item.Gender</span>
                            </div>
                            <div class="sp-row">
                                <span class="sp-label">Mobile</span>
                                <span class="sp-value">@item.MobileNumber</span>
                            </div>
                            <div class="sp-row">
                                <span class="sp-label">Referred By</span>
                                <span class="sp-value">@item.ReferredBy</span>
                            </div>
                            <div class="sp-row">
                                <span class="sp-label">Address</span>
                                <span class="sp-value" style="color:#64748B; font-weight:400;">
                                    @($"{item.AddressTypes} - {item.AddressLine1} - {item.CountryName} - {item.PinCode}")
                                </span>
                            </div>
                        </div>
                        <div class="sp-card-footer">
                            <a href="@Url.Action("Edit", "ServiceProvider", new { id = item.ServiceProviderId })"
                               class="action-link">Edit</a>
                            <form asp-action="Delete" asp-controller="ServiceProvider"
                                  method="post" style="display:inline;"
                                  onsubmit="return confirm('Are you sure you want to delete this service Provider?');">
                                <input type="hidden" name="ServiceProviderId" value="@item.ServiceProviderId" />
                                <button type="submit" class="delete-link">Delete</button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="no-data">No Service Providers found.</p>
            }
        </div>

    </div>
</div>
