@model List<ConstructEase.WebApp.ViewModels.ServiceProviderVm>

@{
    ViewData["Title"] = "Service Providers";
}

<style>
    body {
        background: linear-gradient(135deg, #1E3A5F, #0F172A);
        min-height: 100vh;
    }

    .page-container {
        padding: 30px;
        margin-top: 80px;
    }

    .card-box {
        background: #ffffff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .header-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        margin-bottom: 20px;
    }

    .header-left {
        justify-self: start;
    }

    .header-center {
        justify-self: center;
    }

    .header-right {
        justify-self: end;
    }

    .title {
        font-size: 28px;
        font-weight: 600;
        color: #1E293B;
    }

    .btn-add {
        background: #F59E0B;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-add:hover {
            background: #D97706;
        }

    .badge-box {
        display: inline-block;
        background: #1E3A5F;
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 500;
        margin-bottom: 15px;
    }

        .badge-box span {
            background: #F59E0B;
            padding: 4px 10px;
            border-radius: 12px;
            margin-left: 8px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 12px;
    }

    thead {
        background: #1E3A5F;
        color: white;
    }

    th {
        padding: 14px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 12px;
        font-size: 16px;
        border-bottom: 1px solid #eee;
    }

    tbody tr:hover {
        background: #f9fafb;
    }

    .action-link {
        color: #16A34A;
        font-weight: 500;
        text-decoration: none;
        margin-right: 8px;
    }

        .action-link:hover {
            text-decoration: underline;
        }

    .delete-link {
        color: #DC2626;
        font-weight: 500;
        border: none;
        background: none;
    }

        .delete-link:hover {
            text-decoration: underline;
        }

    .address-text {
        color: #64748B;
        font-size: 16px;
    }

    .no-data {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">
    <div class="card-box">

        <div class="header-row">

            <div class="header-left">
                <div class="badge-box">
                    Total Service Providers <span>@ViewBag.ServiceProviderCount</span>
                </div>
            </div>

            <div class="header-center">
                <div class="title">Service Providers / Vendor</div>
            </div>

            <div class="header-right">
                <a asp-controller="ServiceProvider" asp-action="Add" class="btn-add">+ Add New</a>
            </div>

        </div>

        <span class="text-success">
            @TempData["AddSuccessMessage"]
            @TempData["UpdateSuccessMessage"]
            @TempData["DeleteSuccessMessage"]
        </span>

        <table>
            <thead>
                <tr>
                    <th>Service Type</th>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Mobile</th>
                    <th>Referred By</th>
                    <th>Address</th>
                    <th style="width:140px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ServiceTypes</td>
                            <td>@item.ServiceProviderName</td>
                            <td>@item.Gender</td>
                            <td>@item.MobileNumber</td>
                            <td>@item.ReferredBy</td>
                            <td class="address-text">
                                @($"{item.AddressTypes} - {item.AddressLine1} - {item.CountryName} - {item.PinCode}")
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "ServiceProvider", new { id = item.ServiceProviderId })"
                                   class="action-link">Edit</a>

                                <form asp-action="Delete" asp-controller="ServiceProvider"
                                      method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete this service Provider?');">

                                    <input type="hidden" name="ServiceProviderId" value="@item.ServiceProviderId" />
                                    <button type="submit" class="delete-link">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="no-data">No Service Providers found.</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>